{
	default_bind 0.0.0.0
	http_port {$CADDY_HTTP_PORT}
	https_port {$CADDY_HTTPS_PORT}

	log {
		format console
		output stdout
		level ERROR
	}

	skip_install_trust

	pki {
		ca citm {
			root {
				cert /certs/rootCA.pem
				key /certs/rootCA-key.pem
			}
		}
	}
}

(dev_certs) {
	tls {
		on_demand
		issuer internal {
			ca citm
		}
	}
}

https://citm.internal:{$CADDY_ADMIN_PORT}, https://*.citm.internal:{$CADDY_ADMIN_PORT}, https://citm.localhost:{$CADDY_ADMIN_PORT}, https://*.citm.localhost:{$CADDY_ADMIN_PORT} {
	import dev_certs

	@mitm `{host}.startsWith("mitm.citm.")`
	handle @mitm {
		reverse_proxy {
			to 127.0.0.1:{$MITMPROXY_WEB_PORT}
			header_up Authorization "Bearer secret"
			header_up -Origin

			transport http {
				network_proxy none
			}
		}
	}

	@utils `{host}.startsWith("utils.citm.")`
	handle @utils {
		reverse_proxy {
			to 127.0.0.1:{$CITM_UTILS_WEB_PORT}

			transport http {
				network_proxy none
			}
		}
	}

	@supervisor `{host}.startsWith("supervisor.citm.")`
	handle @supervisor {
		reverse_proxy {
			to 127.0.0.1:{$SUPERVISOR_WEBUI_PORT}

			transport http {
				network_proxy none
			}
		}
	}

	respond "Unknown service" 404
}

import /etc/caddy/conf.d/*
