# example-playground/justfile

# Start all playground services (gateway, service1, service2)
up:
    docker compose -f gateway/compose.yml up -d
    docker compose -f service1/compose.yml up -d
    docker compose -f service2/compose.yml up -d
    @echo "✅ All playground services are running."
    @echo "   You can view the proxy UI at: https://mitm.citm.localhost:3858"

# Stop all playground services
down:
    docker compose -f service2/compose.yml down
    docker compose -f service1/compose.yml down
    docker compose -f gateway/compose.yml down
    @echo "🛑 All playground services stopped."

# Restart all playground services
restart: down up

# View logs for the gateway
logs-gateway:
    docker compose -f gateway/compose.yml logs -f

# View logs for service1 (traefik/whoami)
logs-service1:
    docker compose -f service1/compose.yml logs -f

# View logs for service2 (the python script pinging service1)
logs-service2:
    docker compose -f service2/compose.yml logs -f
